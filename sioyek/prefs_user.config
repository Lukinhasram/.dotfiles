# === EVERFOREST HARD DARK THEME === #

# Main Background (Hard Dark)
background_color               #272e33

# Status Bar (Darker Green Background, Green Text)
status_bar_color               #1e2521
status_bar_text_color          #a7c080

# Selection & Marks
text_highlight_color           #dbbc7f
visual_mark_color              #5c6a72

# Search, Links, & SyncTeX
search_highlight_color         #dbbc7f
link_highlight_color           #7fbbb3
synctex_highlight_color        #a7c080

# Highlight Palette
highlight_color_a              #e67e80
highlight_color_b              #e69875
highlight_color_c              #dbbc7f
highlight_color_d              #a7c080
highlight_color_e              #83c092
highlight_color_f              #7fbbb3
highlight_color_g              #d699b6

# Custom Document Colors (Inverts the PDF to Hard Dark)
custom_background_color        #272e33
custom_text_color              #d3c6aa

# User Interface Colors (Slightly darker than the page for contrast)
ui_text_color                  #d3c6aa
ui_background_color            #1e2326
ui_selected_text_color         #a7c080
ui_selected_background_color   #374145

# =============== #
super_fast_search 1
startup_commands toggle_custom_color
